<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>星际突击队 / Star Fighter</title>
<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 20%, rgba(77, 58, 160, 0.36), transparent 38%),
      linear-gradient(180deg, #070814 0%, #09051a 48%, #02040a 100%);
    color: #dff8ff;
    font-family: Consolas, Monaco, "Courier New", monospace;
  }

  body {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .game-shell {
    position: relative;
    width: min(96vw, 520px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px;
    border: 1px solid rgba(80, 218, 255, 0.26);
    border-radius: 8px;
    background: rgba(2, 8, 22, 0.52);
    box-shadow:
      0 0 28px rgba(0, 210, 255, 0.28),
      0 0 80px rgba(154, 70, 255, 0.16),
      inset 0 0 20px rgba(80, 210, 255, 0.1);
  }

  canvas {
    width: min(90vw, 480px);
    height: auto;
    aspect-ratio: 2 / 3;
    display: block;
    border-radius: 6px;
    background: #020613;
    box-shadow:
      0 0 0 1px rgba(127, 232, 255, 0.55),
      0 0 22px rgba(0, 191, 255, 0.42);
    touch-action: none;
  }

  .scanline {
    pointer-events: none;
    position: absolute;
    inset: 14px;
    border-radius: 6px;
    background: repeating-linear-gradient(
      180deg,
      rgba(255,255,255,0.03) 0px,
      rgba(255,255,255,0.03) 1px,
      transparent 2px,
      transparent 4px
    );
    mix-blend-mode: screen;
    opacity: 0.28;
  }
</style>
</head>
<body>
  <div class="game-shell">
    <canvas id="gameCanvas" width="480" height="720"></canvas>
    <div class="scanline"></div>
  </div>

<script>
"use strict";

/* =========================================================
   1. 常量配置
========================================================= */
const CONFIG = {
  width: 480,
  height: 720,
  playerSpeed: 5,
  playerBulletSpeed: 8,
  enemyBulletBaseSpeed: 3,
  playerFireCooldown: 180,
  invincibleTime: 1000,
  shieldTime: 5000,
  initialEnemySpawn: 900,
  minEnemySpawn: 250,
  powerDropChance: 0.15,
  maxParticles: 360,
  levelScore: 500,
  maxLives: 5,
  difficulties: {
    easy: { label: "Easy", enemyRate: 1.15, enemyPower: 0.85, drop: 0.2 },
    normal: { label: "Normal", enemyRate: 1, enemyPower: 1, drop: 0.15 },
    hard: { label: "Hard", enemyRate: 0.78, enemyPower: 1.2, drop: 0.12 }
  }
};

const STATE = {
  START: "start",
  PLAYING: "playing",
  PAUSED: "paused",
  GAME_OVER: "gameOver"
};

const ENEMY_TYPES = {
  normal: {
    hp: 1, speed: 2, score: 10, radius: 16,
    color: "#33e3ff", accent: "#a6fbff"
  },
  fast: {
    hp: 1, speed: 4, score: 20, radius: 13,
    color: "#ff6b35", accent: "#ffd166"
  },
  heavy: {
    hp: 4, speed: 1.2, score: 50, radius: 25,
    color: "#9a63ff", accent: "#f0ccff"
  },
  elite: {
    hp: 8, speed: 1.5, score: 100, radius: 31,
    color: "#ff3f9e", accent: "#ffc2f0"
  }
};

/* =========================================================
   2. 工具函数
========================================================= */
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

function clamp(value, min, max) {
  return Math.max(min, Math.min(max, value));
}

function rand(min, max) {
  return Math.random() * (max - min) + min;
}

function randInt(min, max) {
  return Math.floor(rand(min, max + 1));
}

function distance(a, b) {
  return Math.hypot(a.x - b.x, a.y - b.y);
}

function circleHit(a, b) {
  return distance(a, b) < a.radius + b.radius;
}

function drawGlowCircle(ctx, x, y, radius, color, alpha) {
  ctx.save();
  ctx.globalAlpha = alpha;
  ctx.shadowColor = color;
  ctx.shadowBlur = radius * 1.8;
  ctx.fillStyle = color;
  ctx.beginPath();
  ctx.arc(x, y, radius, 0, Math.PI * 2);
  ctx.fill();
  ctx.restore();
}

function getTouchPoint(evt) {
  const rect = canvas.getBoundingClientRect();
  const touch = evt.touches[0] || evt.changedTouches[0];
  return {
    x: (touch.clientX - rect.left) * (CONFIG.width / rect.width),
    y: (touch.clientY - rect.top) * (CONFIG.height / rect.height)
  };
}

/* =========================================================
   3. 输入控制
========================================================= */
const input = {
  keys: Object.create(null),
  pointerActive: false,
  pointerX: CONFIG.width / 2,
  pointerY: CONFIG.height - 90
};

window.addEventListener("keydown", (e) => {
  input.keys[e.code] = true;
  audio.ensure();

  if (["Space", "ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].includes(e.code)) {
    e.preventDefault();
  }

  if (game.state === STATE.START) {
    if (e.code === "Enter") game.startGame();
    if (e.code === "Digit1") game.difficulty = "easy";
    if (e.code === "Digit2") game.difficulty = "normal";
    if (e.code === "Digit3") game.difficulty = "hard";
  } else if (game.state === STATE.PLAYING && e.code === "KeyP") {
    game.pause();
  } else if (game.state === STATE.PAUSED && e.code === "KeyP") {
    game.resume();
  } else if (game.state === STATE.GAME_OVER && e.code === "KeyR") {
    game.startGame();
  }
});

window.addEventListener("keyup", (e) => {
  input.keys[e.code] = false;
});

canvas.addEventListener("pointerdown", (e) => {
  audio.ensure();
  if (game.state === STATE.START) {
    game.startGame();
    return;
  }
  if (game.state === STATE.GAME_OVER) {
    game.startGame();
    return;
  }
  input.pointerActive = true;
  const rect = canvas.getBoundingClientRect();
  input.pointerX = (e.clientX - rect.left) * (CONFIG.width / rect.width);
  input.pointerY = (e.clientY - rect.top) * (CONFIG.height / rect.height);
});

canvas.addEventListener("pointermove", (e) => {
  if (!input.pointerActive) return;
  const rect = canvas.getBoundingClientRect();
  input.pointerX = (e.clientX - rect.left) * (CONFIG.width / rect.width);
  input.pointerY = (e.clientY - rect.top) * (CONFIG.height / rect.height);
});

window.addEventListener("pointerup", () => {
  input.pointerActive = false;
});

canvas.addEventListener("touchmove", (e) => e.preventDefault(), { passive: false });

/* =========================================================
   4. 音效系统
========================================================= */
const audio = {
  ctx: null,
  master: null,

  ensure() {
    if (this.ctx) return;
    const AudioContext = window.AudioContext || window.webkitAudioContext;
    if (!AudioContext) return;

    this.ctx = new AudioContext();
    this.master = this.ctx.createGain();
    this.master.gain.value = 0.18;
    this.master.connect(this.ctx.destination);
  },

  tone(freq, duration, type, volume, slideTo) {
    if (!this.ctx) return;

    const now = this.ctx.currentTime;
    const osc = this.ctx.createOscillator();
    const gain = this.ctx.createGain();

    osc.type = type || "sine";
    osc.frequency.setValueAtTime(freq, now);
    if (slideTo) osc.frequency.exponentialRampToValueAtTime(slideTo, now + duration);

    gain.gain.setValueAtTime(0.0001, now);
    gain.gain.exponentialRampToValueAtTime(volume, now + 0.015);
    gain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

    osc.connect(gain);
    gain.connect(this.master);
    osc.start(now);
    osc.stop(now + duration + 0.03);
  },

  play(type) {
    if (!this.ctx) return;

    if (type === "shoot") {
      this.tone(720, 0.055, "triangle", 0.18, 1040);
    } else if (type === "explosion") {
      this.tone(120, 0.18, "sawtooth", 0.18, 45);
      this.tone(240, 0.1, "square", 0.06, 90);
    } else if (type === "hurt") {
      this.tone(170, 0.22, "square", 0.2, 70);
    } else if (type === "pickup") {
      this.tone(520, 0.08, "sine", 0.16, 880);
      setTimeout(() => this.tone(860, 0.08, "sine", 0.13, 1320), 55);
    } else if (type === "start") {
      this.tone(300, 0.08, "triangle", 0.16, 450);
      setTimeout(() => this.tone(600, 0.11, "triangle", 0.16, 900), 75);
    } else if (type === "gameOver") {
      this.tone(360, 0.18, "sawtooth", 0.16, 180);
      setTimeout(() => this.tone(180, 0.28, "sawtooth", 0.14, 70), 120);
    } else if (type === "level") {
      this.tone(500, 0.08, "triangle", 0.15, 750);
      setTimeout(() => this.tone(760, 0.1, "triangle", 0.15, 1180), 70);
    }
  }
};

/* =========================================================
   5. 游戏对象类
========================================================= */
class Player {
  constructor() {
    this.x = CONFIG.width / 2;
    this.y = CONFIG.height - 88;
    this.radius = 18;
    this.speed = CONFIG.playerSpeed;
    this.lives = 3;
    this.weapon = 1;
    this.lastShot = 0;
    this.invincibleUntil = 0;
    this.shieldUntil = 0;
  }

  reset() {
    this.x = CONFIG.width / 2;
    this.y = CONFIG.height - 88;
    this.lives = 3;
    this.weapon = 1;
    this.lastShot = 0;
    this.invincibleUntil = 0;
    this.shieldUntil = 0;
  }

  hasShield(now) {
    return this.shieldUntil > now;
  }

  isInvincible(now) {
    return this.invincibleUntil > now;
  }

  update(game, now) {
    let dx = 0;
    let dy = 0;

    if (input.keys.KeyA || input.keys.ArrowLeft) dx -= 1;
    if (input.keys.KeyD || input.keys.ArrowRight) dx += 1;
    if (input.keys.KeyW || input.keys.ArrowUp) dy -= 1;
    if (input.keys.KeyS || input.keys.ArrowDown) dy += 1;

    if (input.pointerActive) {
      const ease = 0.22;
      this.x += (input.pointerX - this.x) * ease;
      this.y += (input.pointerY - this.y) * ease;
      if (now - this.lastShot > CONFIG.playerFireCooldown * 0.9) {
        this.shoot(game, now);
      }
    } else {
      if (dx || dy) {
        const len = Math.hypot(dx, dy) || 1;
        this.x += (dx / len) * this.speed;
        this.y += (dy / len) * this.speed;
      }

      if (input.keys.Space) this.shoot(game, now);
    }

    this.x = clamp(this.x, this.radius + 5, CONFIG.width - this.radius - 5);
    this.y = clamp(this.y, this.radius + 5, CONFIG.height - this.radius - 5);

    game.addTailFlame(this.x, this.y + 23);
  }

  shoot(game, now) {
    if (now - this.lastShot < CONFIG.playerFireCooldown) return;
    this.lastShot = now;
    audio.play("shoot");

    const patterns = {
      1: [{ ox: 0, vx: 0 }],
      2: [{ ox: -8, vx: 0 }, { ox: 8, vx: 0 }],
      3: [{ ox: 0, vx: 0 }, { ox: -10, vx: -1.2 }, { ox: 10, vx: 1.2 }],
      4: [
        { ox: 0, vx: 0 },
        { ox: -9, vx: -1.0 },
        { ox: 9, vx: 1.0 },
        { ox: -15, vx: -2.0 },
        { ox: 15, vx: 2.0 }
      ]
    };

    const list = patterns[this.weapon] || patterns[4];
    for (const p of list) {
      game.playerBullets.push(new Bullet(this.x + p.ox, this.y - 24, p.vx, -CONFIG.playerBulletSpeed));
    }
  }

  hit(game, now) {
    if (this.hasShield(now) || this.isInvincible(now)) return false;

    this.lives -= 1;
    this.invincibleUntil = now + CONFIG.invincibleTime;
    game.shake = Math.max(game.shake, 10);
    game.flash = 0.34;
    game.combo = 0;
    audio.play("hurt");

    for (let i = 0; i < 28; i++) {
      game.spawnParticle(this.x, this.y, "#4deaff", rand(1, 4), rand(280, 720), rand(0, Math.PI * 2), rand(260, 520));
    }

    if (this.lives <= 0) game.endGame();
    return true;
  }

  draw(ctx, now) {
    const blinking = this.isInvincible(now) && Math.floor(now / 90) % 2 === 0;
    if (blinking) ctx.globalAlpha = 0.38;

    ctx.save();
    ctx.translate(this.x, this.y);

    if (this.hasShield(now)) {
      const pulse = 1 + Math.sin(now * 0.008) * 0.04;
      ctx.save();
      ctx.globalAlpha = 0.42;
      ctx.strokeStyle = "#ffd166";
      ctx.fillStyle = "rgba(255, 209, 102, 0.08)";
      ctx.shadowColor = "#ffd166";
      ctx.shadowBlur = 18;
      ctx.lineWidth = 3;
      ctx.beginPath();
      ctx.arc(0, 0, 34 * pulse, 0, Math.PI * 2);
      ctx.fill();
      ctx.stroke();
      ctx.restore();
    }

    ctx.shadowColor = "#38e8ff";
    ctx.shadowBlur = 18;

    ctx.fillStyle = "#54f2ff";
    ctx.beginPath();
    ctx.moveTo(0, -28);
    ctx.lineTo(14, 14);
    ctx.lineTo(0, 7);
    ctx.lineTo(-14, 14);
    ctx.closePath();
    ctx.fill();

    ctx.fillStyle = "#1688ff";
    ctx.beginPath();
    ctx.moveTo(-13, 2);
    ctx.lineTo(-34, 18);
    ctx.lineTo(-9, 20);
    ctx.closePath();
    ctx.fill();

    ctx.beginPath();
    ctx.moveTo(13, 2);
    ctx.lineTo(34, 18);
    ctx.lineTo(9, 20);
    ctx.closePath();
    ctx.fill();

    ctx.fillStyle = "#dffbff";
    ctx.beginPath();
    ctx.moveTo(0, -18);
    ctx.lineTo(6, 5);
    ctx.lineTo(0, 10);
    ctx.lineTo(-6, 5);
    ctx.closePath();
    ctx.fill();

    const flame = 12 + Math.sin(now * 0.04) * 5;
    ctx.shadowColor = "#ffcf5c";
    ctx.shadowBlur = 16;
    ctx.fillStyle = "#ffcf5c";
    ctx.beginPath();
    ctx.moveTo(-6, 17);
    ctx.lineTo(0, 17 + flame);
    ctx.lineTo(6, 17);
    ctx.closePath();
    ctx.fill();

    ctx.fillStyle = "#ff6d4f";
    ctx.beginPath();
    ctx.moveTo(-3, 17);
    ctx.lineTo(0, 17 + flame * 0.65);
    ctx.lineTo(3, 17);
    ctx.closePath();
    ctx.fill();

    ctx.restore();
    ctx.globalAlpha = 1;
  }
}

class Bullet {
  constructor(x, y, vx, vy) {
    this.x = x;
    this.y = y;
    this.vx = vx;
    this.vy = vy;
    this.radius = 4;
    this.damage = 1;
    this.dead = false;
  }

  update() {
    this.x += this.vx;
    this.y += this.vy;
    if (this.y < -20 || this.x < -30 || this.x > CONFIG.width + 30) this.dead = true;
  }

  draw(ctx) {
    ctx.save();
    ctx.shadowColor = "#aef7ff";
    ctx.shadowBlur = 14;
    ctx.strokeStyle = "rgba(128, 236, 255, 0.55)";
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(this.x, this.y + 12);
    ctx.lineTo(this.x - this.vx * 0.7, this.y + 2);
    ctx.stroke();

    ctx.fillStyle = "#eaffff";
    ctx.beginPath();
    ctx.ellipse(this.x, this.y, 3, 8, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  }
}

class Enemy {
  constructor(type, level, difficultyPower) {
    const cfg = ENEMY_TYPES[type];
    this.type = type;
    this.x = rand(cfg.radius + 10, CONFIG.width - cfg.radius - 10);
    this.y = -cfg.radius - 10;
    this.radius = cfg.radius;
    this.maxHp = Math.ceil(cfg.hp + Math.max(0, level - 1) * 0.18 * difficultyPower);
    this.hp = this.maxHp;
    this.speed = cfg.speed * (1 + (level - 1) * 0.035) * difficultyPower;
    this.score = cfg.score;
    this.color = cfg.color;
    this.accent = cfg.accent;
    this.dead = false;
    this.phase = rand(0, Math.PI * 2);
    this.hitFlash = 0;
    this.lastShot = 0;
    this.shootCooldown = rand(1200, 1900);
  }

  update(game, now) {
    this.y += this.speed;

    if (this.type === "fast") {
      this.x += Math.sin(now * 0.006 + this.phase) * 1.4;
    }

    if (this.type === "elite" && now - this.lastShot > this.shootCooldown) {
      this.lastShot = now;
      this.shootCooldown = rand(1200, 1850) / Math.min(1.5, 1 + game.level * 0.03);
      const dx = game.player.x - this.x;
      const dy = game.player.y - this.y;
      const len = Math.hypot(dx, dy) || 1;
      const spd = CONFIG.enemyBulletBaseSpeed * (1 + game.level * 0.025) * game.diff.enemyPower;
      game.enemyBullets.push(new EnemyBullet(this.x, this.y + this.radius * 0.5, (dx / len) * spd, (dy / len) * spd));
    }

    this.hitFlash *= 0.82;
    if (this.y > CONFIG.height + this.radius + 40) this.dead = true;
  }

  damage(game, amount) {
    this.hp -= amount;
    this.hitFlash = 1;
    for (let i = 0; i < 5; i++) {
      game.spawnParticle(this.x, this.y, this.accent, rand(1, 3), rand(80, 220), rand(0, Math.PI * 2), rand(120, 220));
    }
    if (this.hp <= 0) this.kill(game);
  }

  kill(game) {
    this.dead = true;
    const comboBonus = Math.min(80, game.combo * 2);
    const gained = this.score + comboBonus;
    game.score += gained;
    game.combo += 1;
    game.comboTimer = 1600;
    game.floatingTexts.push(new FloatingText(this.x, this.y, "+" + gained, this.accent));
    game.explode(this.x, this.y, this.color, this.radius);
    game.shake = Math.max(game.shake, this.type === "elite" ? 8 : 4);
    audio.play("explosion");

    if (Math.random() < game.diff.drop) {
      game.spawnPowerUp(this.x, this.y);
    }
  }

  draw(ctx) {
    const cfg = ENEMY_TYPES[this.type];

    ctx.save();
    ctx.translate(this.x, this.y);
    ctx.shadowColor = cfg.color;
    ctx.shadowBlur = 14 + this.hitFlash * 12;

    if (this.hitFlash > 0.15) {
      ctx.globalAlpha = 0.78;
      ctx.fillStyle = "#ffffff";
    } else {
      ctx.fillStyle = cfg.color;
    }

    if (this.type === "normal") {
      ctx.beginPath();
      ctx.moveTo(0, 20);
      ctx.lineTo(16, -12);
      ctx.lineTo(0, -5);
      ctx.lineTo(-16, -12);
      ctx.closePath();
      ctx.fill();
    } else if (this.type === "fast") {
      ctx.rotate(Math.sin(this.phase + this.y * 0.02) * 0.08);
      ctx.beginPath();
      ctx.moveTo(0, 17);
      ctx.lineTo(22, -3);
      ctx.lineTo(7, -15);
      ctx.lineTo(0, -9);
      ctx.lineTo(-7, -15);
      ctx.lineTo(-22, -3);
      ctx.closePath();
      ctx.fill();
    } else if (this.type === "heavy") {
      ctx.beginPath();
      ctx.roundRect(-24, -18, 48, 36, 8);
      ctx.fill();
      ctx.fillStyle = cfg.accent;
      ctx.fillRect(-15, -4, 30, 7);
    } else {
      ctx.beginPath();
      ctx.moveTo(0, 30);
      ctx.lineTo(28, 8);
      ctx.lineTo(22, -22);
      ctx.lineTo(0, -12);
      ctx.lineTo(-22, -22);
      ctx.lineTo(-28, 8);
      ctx.closePath();
      ctx.fill();

      ctx.fillStyle = cfg.accent;
      ctx.beginPath();
      ctx.arc(0, 2, 9, 0, Math.PI * 2);
      ctx.fill();
    }

    if (this.maxHp > 1) {
      const w = this.radius * 1.7;
      const pct = clamp(this.hp / this.maxHp, 0, 1);
      ctx.shadowBlur = 0;
      ctx.fillStyle = "rgba(0,0,0,0.55)";
      ctx.fillRect(-w / 2, -this.radius - 12, w, 4);
      ctx.fillStyle = cfg.accent;
      ctx.fillRect(-w / 2, -this.radius - 12, w * pct, 4);
    }

    ctx.restore();
  }
}

class EnemyBullet {
  constructor(x, y, vx, vy) {
    this.x = x;
    this.y = y;
    this.vx = vx;
    this.vy = vy;
    this.radius = 5;
    this.dead = false;
  }

  update() {
    this.x += this.vx;
    this.y += this.vy;
    if (this.x < -30 || this.x > CONFIG.width + 30 || this.y < -40 || this.y > CONFIG.height + 40) {
      this.dead = true;
    }
  }

  draw(ctx) {
    ctx.save();
    ctx.shadowColor = "#ff743a";
    ctx.shadowBlur = 16;
    ctx.fillStyle = "#ffdd7a";
    ctx.beginPath();
    ctx.arc(this.x, this.y, 4.6, 0, Math.PI * 2);
    ctx.fill();
    ctx.strokeStyle = "rgba(255, 86, 34, 0.55)";
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(this.x - this.vx * 2, this.y - this.vy * 2);
    ctx.lineTo(this.x, this.y);
    ctx.stroke();
    ctx.restore();
  }
}

class PowerUp {
  constructor(x, y, type) {
    this.x = x;
    this.y = y;
    this.type = type;
    this.radius = 15;
    this.vy = 1.6;
    this.angle = 0;
    this.dead = false;

    if (type === "power") {
      this.color = "#46e6ff";
      this.text = "P";
    } else if (type === "life") {
      this.color = "#5dff98";
      this.text = "+";
    } else {
      this.color = "#ffd166";
      this.text = "S";
    }
  }

  update() {
    this.y += this.vy;
    this.angle += 0.045;
    if (this.y > CONFIG.height + 30) this.dead = true;
  }

  apply(game) {
    this.dead = true;
    audio.play("pickup");

    if (this.type === "power") {
      game.player.weapon = clamp(game.player.weapon + 1, 1, 4);
      game.floatingTexts.push(new FloatingText(this.x, this.y, "POWER UP!", this.color));
    } else if (this.type === "life") {
      game.player.lives = clamp(game.player.lives + 1, 0, CONFIG.maxLives);
      game.floatingTexts.push(new FloatingText(this.x, this.y, "LIFE +1", this.color));
    } else {
      game.player.shieldUntil = performance.now() + CONFIG.shieldTime;
      game.floatingTexts.push(new FloatingText(this.x, this.y, "SHIELD!", this.color));
    }

    for (let i = 0; i < 24; i++) {
      game.spawnParticle(this.x, this.y, this.color, rand(1.2, 3.2), rand(100, 260), rand(0, Math.PI * 2), rand(220, 420));
    }
  }

  draw(ctx) {
    ctx.save();
    ctx.translate(this.x, this.y);
    ctx.rotate(this.angle);
    ctx.shadowColor = this.color;
    ctx.shadowBlur = 18;
    ctx.strokeStyle = this.color;
    ctx.fillStyle = "rgba(255,255,255,0.08)";
    ctx.lineWidth = 3;

    ctx.beginPath();
    for (let i = 0; i < 6; i++) {
      const a = (Math.PI * 2 / 6) * i;
      const r = i % 2 === 0 ? 16 : 10;
      const px = Math.cos(a) * r;
      const py = Math.sin(a) * r;
      if (i === 0) ctx.moveTo(px, py);
      else ctx.lineTo(px, py);
    }
    ctx.closePath();
    ctx.fill();
    ctx.stroke();

    ctx.rotate(-this.angle);
    ctx.fillStyle = "#ffffff";
    ctx.font = "bold 15px Consolas, monospace";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(this.text, 0, 1);
    ctx.restore();
  }
}

class Particle {
  constructor(x, y, vx, vy, color, size, life) {
    this.x = x;
    this.y = y;
    this.vx = vx;
    this.vy = vy;
    this.color = color;
    this.size = size;
    this.life = life;
    this.maxLife = life;
    this.dead = false;
  }

  update(dt) {
    this.x += this.vx * dt;
    this.y += this.vy * dt;
    this.vx *= 0.985;
    this.vy *= 0.985;
    this.life -= dt * 1000;
    if (this.life <= 0) this.dead = true;
  }

  draw(ctx) {
    const a = clamp(this.life / this.maxLife, 0, 1);
    ctx.save();
    ctx.globalAlpha = a;
    ctx.shadowColor = this.color;
    ctx.shadowBlur = 10;
    ctx.fillStyle = this.color;
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.size * a, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  }
}

class FloatingText {
  constructor(x, y, text, color) {
    this.x = x;
    this.y = y;
    this.text = text;
    this.color = color || "#dffbff";
    this.life = 900;
    this.maxLife = 900;
    this.dead = false;
  }

  update(dt) {
    this.y -= 38 * dt;
    this.life -= dt * 1000;
    if (this.life <= 0) this.dead = true;
  }

  draw(ctx) {
    const a = clamp(this.life / this.maxLife, 0, 1);
    ctx.save();
    ctx.globalAlpha = a;
    ctx.shadowColor = this.color;
    ctx.shadowBlur = 12;
    ctx.fillStyle = this.color;
    ctx.font = "bold 16px Consolas, monospace";
    ctx.textAlign = "center";
    ctx.fillText(this.text, this.x, this.y);
    ctx.restore();
  }
}

/* =========================================================
   6. 游戏主对象
========================================================= */
class Game {
  constructor() {
    this.state = STATE.START;
    this.player = new Player();
    this.playerBullets = [];
    this.enemyBullets = [];
    this.enemies = [];
    this.powerUps = [];
    this.particles = [];
    this.floatingTexts = [];
    this.stars = [];
    this.meteors = [];

    this.score = 0;
    this.level = 1;
    this.highScore = Number(localStorage.getItem("starFighterHighScore") || 0);
    this.enemyTimer = 0;
    this.enemyInterval = CONFIG.initialEnemySpawn;
    this.levelTextTimer = 0;
    this.combo = 0;
    this.comboTimer = 0;
    this.flash = 0;
    this.shake = 0;
    this.difficulty = "normal";
    this.diff = CONFIG.difficulties.normal;

    this.lastTime = performance.now();
    this.initStars();
  }

  initStars() {
    this.stars = [];
    for (let i = 0; i < 120; i++) {
      this.stars.push({
        x: rand(0, CONFIG.width),
        y: rand(0, CONFIG.height),
        r: rand(0.6, 2.2),
        speed: rand(0.25, 1.7),
        alpha: rand(0.35, 1)
      });
    }
  }

  startGame() {
    this.state = STATE.PLAYING;
    this.diff = CONFIG.difficulties[this.difficulty] || CONFIG.difficulties.normal;
    this.player.reset();
    this.playerBullets.length = 0;
    this.enemyBullets.length = 0;
    this.enemies.length = 0;
    this.powerUps.length = 0;
    this.particles.length = 0;
    this.floatingTexts.length = 0;
    this.meteors.length = 0;
    this.score = 0;
    this.level = 1;
    this.enemyTimer = 0;
    this.enemyInterval = CONFIG.initialEnemySpawn * this.diff.enemyRate;
    this.levelTextTimer = 0;
    this.combo = 0;
    this.comboTimer = 0;
    this.flash = 0;
    this.shake = 0;
    audio.play("start");
  }

  pause() {
    this.state = STATE.PAUSED;
  }

  resume() {
    this.state = STATE.PLAYING;
    this.lastTime = performance.now();
  }

  endGame() {
    this.state = STATE.GAME_OVER;
    this.highScore = Math.max(this.highScore, this.score);
    localStorage.setItem("starFighterHighScore", String(this.highScore));
    audio.play("gameOver");
  }

  update(now, dt) {
    this.updateBackground(dt);

    if (this.state !== STATE.PLAYING) {
      this.updateEffects(dt);
      return;
    }

    const oldLevel = this.level;
    this.level = Math.max(1, Math.floor(this.score / CONFIG.levelScore) + 1);
    if (this.level > oldLevel) {
      this.levelTextTimer = 1200;
      this.floatingTexts.push(new FloatingText(CONFIG.width / 2, CONFIG.height / 2 - 45, "LEVEL UP!", "#f7ec77"));
      audio.play("level");
    }

    this.enemyInterval = clamp(
      (CONFIG.initialEnemySpawn - (this.level - 1) * 38) * this.diff.enemyRate,
      CONFIG.minEnemySpawn,
      CONFIG.initialEnemySpawn
    );

    this.enemyTimer += dt * 1000;
    if (this.enemyTimer >= this.enemyInterval) {
      this.enemyTimer = 0;
      this.spawnEnemy();
    }

    this.player.update(this, now);

    for (const bullet of this.playerBullets) bullet.update(dt);
    for (const bullet of this.enemyBullets) bullet.update(dt);
    for (const enemy of this.enemies) enemy.update(this, now);
    for (const power of this.powerUps) power.update(dt);

    this.handleCollisions(now);
    this.updateEffects(dt);
    this.cleanup();

    this.comboTimer -= dt * 1000;
    if (this.comboTimer <= 0) this.combo = 0;

    this.flash = Math.max(0, this.flash - dt * 1.6);
    this.shake *= 0.9;
  }

  updateBackground(dt) {
    for (const star of this.stars) {
      star.y += star.speed * (this.state === STATE.PLAYING ? 1 : 0.35);
      if (star.y > CONFIG.height) {
        star.y = -5;
        star.x = rand(0, CONFIG.width);
      }
    }

    if (Math.random() < 0.004) {
      this.meteors.push({
        x: rand(40, CONFIG.width - 40),
        y: -20,
        vx: rand(-1.5, 1.5),
        vy: rand(6, 9),
        life: 90
      });
    }

    for (const m of this.meteors) {
      m.x += m.vx;
      m.y += m.vy;
      m.life -= 1;
    }

    this.meteors = this.meteors.filter(m => m.life > 0 && m.y < CONFIG.height + 80);
  }

  updateEffects(dt) {
    for (const p of this.particles) p.update(dt);
    for (const t of this.floatingTexts) t.update(dt);
    this.cleanupEffects();
  }

  cleanupEffects() {
    this.particles = this.particles.filter(p => !p.dead).slice(-CONFIG.maxParticles);
    this.floatingTexts = this.floatingTexts.filter(t => !t.dead);
  }

  cleanup() {
    this.playerBullets = this.playerBullets.filter(b => !b.dead);
    this.enemyBullets = this.enemyBullets.filter(b => !b.dead);
    this.enemies = this.enemies.filter(e => !e.dead);
    this.powerUps = this.powerUps.filter(p => !p.dead);
    this.cleanupEffects();
  }

  spawnEnemy() {
    const eliteChance = clamp(0.04 + this.level * 0.006, 0.04, 0.16);
    const heavyChance = clamp(0.12 + this.level * 0.004, 0.12, 0.25);
    const fastChance = 0.28;
    const roll = Math.random();
    let type = "normal";

    if (roll < eliteChance) type = "elite";
    else if (roll < eliteChance + heavyChance) type = "heavy";
    else if (roll < eliteChance + heavyChance + fastChance) type = "fast";

    this.enemies.push(new Enemy(type, this.level, this.diff.enemyPower));
  }

  spawnPowerUp(x, y) {
    const roll = Math.random();
    let type = "power";
    if (roll > 0.68 && this.player.lives < CONFIG.maxLives) type = "life";
    if (roll > 0.86) type = "shield";
    this.powerUps.push(new PowerUp(x, y, type));
  }

  spawnParticle(x, y, color, size, speed, angle, life) {
    if (this.particles.length > CONFIG.maxParticles) return;
    this.particles.push(new Particle(
      x,
      y,
      Math.cos(angle) * speed / 60,
      Math.sin(angle) * speed / 60,
      color,
      size,
      life
    ));
  }

  explode(x, y, color, radius) {
    const count = clamp(Math.floor(radius * 1.6), 16, 54);
    for (let i = 0; i < count; i++) {
      this.spawnParticle(x, y, color, rand(1.4, 4.5), rand(140, 520), rand(0, Math.PI * 2), rand(280, 780));
    }
  }

  addTailFlame(x, y) {
    if (Math.random() < 0.55) {
      this.spawnParticle(x + rand(-5, 5), y, Math.random() < 0.5 ? "#4deaff" : "#ffcf5c", rand(1, 2.8), rand(30, 90), rand(1.1, 2.0), rand(180, 340));
    }
  }

  handleCollisions(now) {
    for (const bullet of this.playerBullets) {
      if (bullet.dead) continue;

      for (const enemy of this.enemies) {
        if (enemy.dead) continue;

        if (circleHit(bullet, enemy)) {
          bullet.dead = true;
          enemy.damage(this, bullet.damage);
          for (let i = 0; i < 7; i++) {
            this.spawnParticle(bullet.x, bullet.y, "#bdfcff", rand(1, 2.4), rand(80, 210), rand(0, Math.PI * 2), rand(120, 260));
          }
          break;
        }
      }
    }

    for (const enemy of this.enemies) {
      if (!enemy.dead && circleHit(this.player, enemy)) {
        const gotHit = this.player.hit(this, now);
        if (gotHit || this.player.hasShield(now)) {
          enemy.hp -= 2;
          if (enemy.hp <= 0) enemy.kill(this);
          else enemy.dead = true;
        }
      }
    }

    for (const bullet of this.enemyBullets) {
      if (!bullet.dead && circleHit(this.player, bullet)) {
        bullet.dead = true;
        this.player.hit(this, now);
      }
    }

    for (const power of this.powerUps) {
      if (!power.dead && circleHit(this.player, power)) {
        power.apply(this);
      }
    }
  }

  draw() {
    ctx.save();
    ctx.clearRect(0, 0, CONFIG.width, CONFIG.height);

    const shakeX = this.shake > 0.3 ? rand(-this.shake, this.shake) : 0;
    const shakeY = this.shake > 0.3 ? rand(-this.shake, this.shake) : 0;
    ctx.translate(shakeX, shakeY);

    this.drawBackground(ctx);

    for (const power of this.powerUps) power.draw(ctx);
    for (const bullet of this.playerBullets) bullet.draw(ctx);
    for (const bullet of this.enemyBullets) bullet.draw(ctx);
    for (const enemy of this.enemies) enemy.draw(ctx);
    for (const p of this.particles) p.draw(ctx);
    this.player.draw(ctx, performance.now());
    for (const text of this.floatingTexts) text.draw(ctx);

    ctx.restore();

    this.drawUI(ctx);

    if (this.flash > 0) {
      ctx.save();
      ctx.globalAlpha = this.flash;
      ctx.fillStyle = "#ff345f";
      ctx.fillRect(0, 0, CONFIG.width, CONFIG.height);
      ctx.restore();
    }

    if (this.state === STATE.START) this.drawStart(ctx);
    if (this.state === STATE.PAUSED) this.drawPause(ctx);
    if (this.state === STATE.GAME_OVER) this.drawGameOver(ctx);
  }

  drawBackground(ctx) {
    const g = ctx.createLinearGradient(0, 0, 0, CONFIG.height);
    g.addColorStop(0, "#030816");
    g.addColorStop(0.45, "#08051d");
    g.addColorStop(1, "#02040b");
    ctx.fillStyle = g;
    ctx.fillRect(-30, -30, CONFIG.width + 60, CONFIG.height + 60);

    ctx.save();
    for (const star of this.stars) {
      ctx.globalAlpha = star.alpha;
      ctx.fillStyle = star.r > 1.6 ? "#aef8ff" : "#ffffff";
      ctx.beginPath();
      ctx.arc(star.x, star.y, star.r, 0, Math.PI * 2);
      ctx.fill();
    }

    ctx.globalAlpha = 0.16;
    ctx.strokeStyle = "#3d8bff";
    ctx.lineWidth = 1;
    for (let y = 0; y < CONFIG.height; y += 72) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(CONFIG.width, y + 28);
      ctx.stroke();
    }

    for (const m of this.meteors) {
      ctx.globalAlpha = clamp(m.life / 90, 0, 1);
      ctx.strokeStyle = "#ddfbff";
      ctx.shadowColor = "#73eaff";
      ctx.shadowBlur = 16;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(m.x, m.y);
      ctx.lineTo(m.x - m.vx * 8, m.y - 34);
      ctx.stroke();
    }
    ctx.restore();
  }

  drawUI(ctx) {
    ctx.save();
    ctx.shadowColor = "#44eaff";
    ctx.shadowBlur = 8;
    ctx.fillStyle = "rgba(3, 16, 35, 0.58)";
    ctx.strokeStyle = "rgba(77, 234, 255, 0.36)";
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.roundRect(12, 12, 456, 46, 8);
    ctx.fill();
    ctx.stroke();

    ctx.fillStyle = "#dffbff";
    ctx.font = "bold 15px Consolas, monospace";
    ctx.textAlign = "left";
    ctx.fillText("Score " + this.score, 24, 31);
    ctx.fillText("Lives " + this.player.lives, 24, 50);
    ctx.fillText("Level " + this.level, 150, 31);
    ctx.fillText("Weapon " + this.player.weapon, 150, 50);

    const now = performance.now();
    const shieldMs = Math.max(0, this.player.shieldUntil - now);
    if (shieldMs > 0) {
      ctx.fillStyle = "#ffd166";
      ctx.fillText("Shield " + (shieldMs / 1000).toFixed(1) + "s", 286, 31);
    } else {
      ctx.fillStyle = "#7acfff";
      ctx.fillText("High " + this.highScore, 286, 31);
    }

    if (this.combo > 1 && this.comboTimer > 0) {
      ctx.fillStyle = "#f7ec77";
      ctx.fillText("Combo x" + this.combo, 286, 50);
    }

    ctx.restore();
  }

  drawOverlayBase(ctx) {
    ctx.save();
    ctx.fillStyle = "rgba(1, 4, 12, 0.72)";
    ctx.fillRect(0, 0, CONFIG.width, CONFIG.height);
    ctx.restore();
  }

  drawStart(ctx) {
    this.drawOverlayBase(ctx);

    ctx.save();
    ctx.textAlign = "center";
    ctx.shadowColor = "#4deaff";
    ctx.shadowBlur = 18;
    ctx.fillStyle = "#eaffff";
    ctx.font = "bold 42px Consolas, monospace";
    ctx.fillText("STAR FIGHTER", CONFIG.width / 2, 168);

    ctx.shadowColor = "#9d6bff";
    ctx.fillStyle = "#bfeeff";
    ctx.font = "bold 22px Consolas, monospace";
    ctx.fillText("星际突击队", CONFIG.width / 2, 205);

    ctx.shadowBlur = 8;
    ctx.fillStyle = "#d6f8ff";
    ctx.font = "15px Consolas, monospace";
    ctx.fillText("WASD / Arrow Move    Space Fire", CONFIG.width / 2, 282);
    ctx.fillText("P Pause    R Restart", CONFIG.width / 2, 310);

    ctx.fillStyle = "#9bc8ff";
    ctx.fillText("在深空航道中突围，收集能量，击落敌军。", CONFIG.width / 2, 362);

    const modes = ["easy", "normal", "hard"];
    for (let i = 0; i < modes.length; i++) {
      const key = modes[i];
      const x = 120 + i * 120;
      const active = this.difficulty === key;
      ctx.fillStyle = active ? "rgba(77, 234, 255, 0.22)" : "rgba(255,255,255,0.06)";
      ctx.strokeStyle = active ? "#4deaff" : "rgba(255,255,255,0.22)";
      ctx.beginPath();
      ctx.roundRect(x - 45, 410, 90, 36, 7);
      ctx.fill();
      ctx.stroke();
      ctx.fillStyle = active ? "#ffffff" : "#9bc8ff";
      ctx.font = "bold 14px Consolas, monospace";
      ctx.fillText((i + 1) + " " + CONFIG.difficulties[key].label, x, 433);
    }

    ctx.fillStyle = "#f7ec77";
    ctx.font = "bold 18px Consolas, monospace";
    ctx.fillText("Press Enter to Start", CONFIG.width / 2, 514);

    ctx.fillStyle = "#7acfff";
    ctx.font = "13px Consolas, monospace";
    ctx.fillText("移动端可直接拖动飞机，自动射击", CONFIG.width / 2, 552);
    ctx.restore();
  }

  drawPause(ctx) {
    this.drawOverlayBase(ctx);
    ctx.save();
    ctx.textAlign = "center";
    ctx.shadowColor = "#4deaff";
    ctx.shadowBlur = 18;
    ctx.fillStyle = "#eaffff";
    ctx.font = "bold 42px Consolas, monospace";
    ctx.fillText("PAUSED", CONFIG.width / 2, CONFIG.height / 2 - 20);
    ctx.font = "16px Consolas, monospace";
    ctx.fillText("Press P to Continue", CONFIG.width / 2, CONFIG.height / 2 + 26);
    ctx.restore();
  }

  drawGameOver(ctx) {
    this.drawOverlayBase(ctx);
    ctx.save();
    ctx.textAlign = "center";
    ctx.shadowColor = "#ff3f9e";
    ctx.shadowBlur = 18;
    ctx.fillStyle = "#ffffff";
    ctx.font = "bold 42px Consolas, monospace";
    ctx.fillText("GAME OVER", CONFIG.width / 2, 250);

    ctx.shadowColor = "#4deaff";
    ctx.font = "bold 20px Consolas, monospace";
    ctx.fillText("Final Score: " + this.score, CONFIG.width / 2, 316);
    ctx.fillText("High Score: " + this.highScore, CONFIG.width / 2, 350);

    ctx.fillStyle = "#f7ec77";
    ctx.font = "bold 18px Consolas, monospace";
    ctx.fillText("Press R to Restart", CONFIG.width / 2, 430);
    ctx.restore();
  }

  loop(now) {
    const dt = Math.min(0.033, (now - this.lastTime) / 1000);
    this.lastTime = now;

    this.update(now, dt);
    this.draw();

    requestAnimationFrame((t) => this.loop(t));
  }
}

/* =========================================================
   7. 初始化逻辑 + 8. 主循环
========================================================= */
const game = new Game();
requestAnimationFrame((t) => game.loop(t));
</script>
</body>
</html>
